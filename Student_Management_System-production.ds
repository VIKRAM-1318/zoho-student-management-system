    			type = email
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Phone_Number
			(
    			type = phonenumber
				displayname = "Phone"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Department
			(
				type = picklist
				maxchar = 100
				values = {"ECE","CSE","EEE","CSE-AI","CIVIL","MECH","AIDS"}
	 			row = 1

	reports
	{
		default list All_Students
		{
			displayName = "All Students"
			show all rows from Student    
			(
				Student_ID
				Student_Name
				Email
				Phone_Number as "Phone"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Department
				YEAR_field as "YEAR"
				STATUS
			)
		}
		default list All_Attendances
		{
			displayName = "All Attendances"
			show all rows from Attendance    
			(
				Attendance_ID
				Student
				Date_field as "Date"
				STATUS
				Faculty
				Present_Flag
			)
		}
		default list All_Faculties
		{
			displayName = "All Faculties"
			show all rows from Faculty    
			(
				Faculty_ID
				Faculty_Name
				Email
				DEPARTMENT
				STATUS
			)
		}
		list ATTENDANCE_REPORT
		{
			displayName = "ATTENDANCE REPORT"
			print template = REPORT1
			show all rows from Attendance    
			(
				Attendance_ID
				Student
				Date_field as "Date"
				STATUS
				Faculty
			)
			filters
			(
				Student
				Date_field
				STATUS
				Faculty
			)
			group by
			(
				Student ascending
			)
		}
		pivottable ATTENDANCE1
		{ 
			displayname = "ATTENDANCE"
			layout = 4
			report properties
			(
				records displayed = all_records
				allow export = false
				allow drilldown and view underlying data = false
		
			)

			based on Autoview_1772455809179_Attendance
				show all rows from Attendance
				(
			Attendance_ID 
			Student 
			Date_field  as "Date"
			STATUS 
			Faculty 
			Present_Flag 
				)
		}
	}


		workflow
		{
		form
		{
			Check_Duplicate_Student_E as "Check_Duplicate_Student_Email"
			{
				type =  form
				form = Student

				record event = on add or edit

				on user input of Email
				{
					actions 
					{
						custom deluge script
						(
											if(Student[Email == input.Email].count() > 0)
										{
											alert "Email already exists";
											input.Email = "";
										}
						)
					}
				}

			}
		}







		form Attendance
		{
			success message = "Attendance Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Attendance_ID
			(
    			type = autonumber
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			Student
			(
				type = picklist	
				values  = Student.ID
    			displayformat = [Student_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Date_field
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			STATUS
			(
				type = picklist
				maxchar = 100
				values = {"PRESENT","ABSENT"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Faculty
			(
				type = picklist	
				values  = Faculty.ID
    			displayformat = [Faculty_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Present_Flag
			(
    			type = formula
				value =  if(STATUS == "Present",1,0)
				visibility = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
